prefix=@PREFIX@
exec_prefix=${prefix}
libdir=@FRAMEWORKSDIR@
includedir=@INCLUDESDIR@

Name: Qt5WebKitWidgets
Description: The Qt WebKitWidgets component
Version: @VERSION@
Libs: -F${libdir} -framework QtWebKitWidgets
Cflags: -I${includedir}/QtWebKitWidgets -I${includedir}
Requires: Qt5Core Qt5Gui Qt5Widgets Qt5Network Qt5WebKit
