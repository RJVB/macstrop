--- src/build-data/cc/clang.txt.orig	2022-06-03 12:29:40.000000000 -0500
+++ src/build-data/cc/clang.txt	2022-10-29 02:06:49.000000000 -0500
@@ -76,9 +76,10 @@
 
 openmp  -> "-fopenmp"
 
-x86_32  -> "-m32"
-x86_64  -> "-m64"
-ppc64   -> "-m64"
+x86_32  -> "-arch i386"
