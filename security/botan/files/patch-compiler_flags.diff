-ppc64   -> "-m64"
-x86_32  -> "-m32"
-x86_64  -> "-m64"
+ppc32   -> "-arch ppc"
+ppc64   -> "-arch ppc64"
+x86_32  -> "-arch i386"
+x86_64  -> "-arch x86_64"
 x32     -> "-mx32"
 
+macos   -> "-stdlib=__MACPORTS_CXX_STDLIB__"
 qnx     -> "-fexceptions"
