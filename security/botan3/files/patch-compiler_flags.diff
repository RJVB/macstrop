--- src/build-data/cc/clang.txt
+++ src/build-data/cc/clang.txt
@@ -76,10 +76,11 @@ all!haiku,llvm -> "-pthread"
 
 openmp  -> "-fopenmp"
 
-x86_32  -> "-m32"
-x86_64  -> "-m64"
-ppc64   -> "-m64"
+x86_32  -> "-arch i386"
