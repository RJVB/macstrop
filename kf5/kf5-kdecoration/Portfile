PortSystem          1.0

set kf5.project     kdecoration
set kf5.virtualPath plasma
PortGroup           kf5 1.1
## upgrade to same version as kf5-kwin (5.20.5 would be nice but imposes a newer kwin5)
# set kf5.latest_plasma 5.16.5
set kf5.latest_plasma 5.18.5
kf5.use_latest      plasma

description         Plugin based library to create window decorations.
long_description    KDecoration2 is a library to create window decorations. These window decorations can be used by \
                    for example an X11 based window manager which re-parents a Client window to a window decoration \
                    frame.

kf5.depends_frameworks \
                    ki18n

patch.pre_args      -Np1

if {${subport} eq "kf5-kdecoration"} {
    # out-comment before committing:
    #distname        kdecoration-git
    # for v5.16.5
    checksums       rmd160  b39ec37a03ba7745249aa09c41d3021d80bf7381 \
                    sha256  2b8c7b7cf114d0eff4ec842009cda264d8cf1254ec4bf65868b6d26f263829bb
#                     size    42780
    # for v5.18.5
    checksums       rmd160  1f56615263efe74de7cb48dd87eed9852a0cdaba \
                    sha256  f09856245f2cb08d9013da4c3128b5438f1e2f58af40031eb547ae765f57a9c8
#                     size    43884

#     # for v5.20.5
#     checksums       rmd160  4bbbdc24d1eb5c84042ebae617c1f010a16e3710 \
#                     sha256  6e973a9b18da376ce797be85fc60b3a1d53ae69868fabeadbefae1279c3181cd
# #                     size    45524
    # the bumped Qt5 and KF5 requirements are just a formality, it turns out... (also for 5.20.5)
    patchfiles-append \
                    patch-support-older-qtkf5-v${version}.diff
}

subport kf5-kdecoration-viewer {
    kf5.set_project kdecoration-viewer
    description     Viewer application for KDecoration2 based decorations
    long_description \
                    ${description}
    homepage        https://projects.kde.org/projects/playground/base/kdecoration-viewer

    fetch.type      git
    kf5.git.setup   kdecoration-viewer
    git.branch      9f5c15b97ad50a691567ba7984cbcf95671fefe7
    version         1.0.0.210524
    worksrcdir      ${subport}-git
    distname        ${subport}-git

    kf5.depends_qt5_components \
                    qtdeclarative
    kf5.depends_frameworks \
                    kconfig kconfigwidgets kdeclarative
    depends_lib-append \
                    port:kf5-kdecoration
    kf5.allow_apidocs_generation \
                    no

    if {[vercmp ${kf5.latest_plasma} 5.18.0] > 0} {
        patchfiles-append \
                    viewer/patch-fix-for-newer-kdecoration.diff
    }

    post-destroot {
        kf5.add_app_wrapper kdecoration-viewer5 kdecorationviewer
    }
}


maintainers         gmail.com:rjvbertin openmaintainer

livecheck.type      regex
livecheck.url       http://download.kde.org/stable/plasma/
livecheck.regex     (5+(\\.\\d+)+)
