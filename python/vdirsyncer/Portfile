# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           python 1.0
PortGroup           github 1.1

name                vdirsyncer

# https://software.intel.com/en-us/license/intel-simplified-software-license
license             Restrictive/Distributable

maintainers         openmaintainer

description         Synchronise calendars and contacts
long_description    Vdirsyncer is a command-line tool for synchronising calendars and \
                    addressbooks between a variety of servers and the local filesystem. \
                    The most popular usecase is to synchronise a server with a local folder \
                    and use a set of other programs to change the local events and contacts. \
                    Vdirsyncer can then synchronise those changes back to the server. \
                    However, vdirsyncer is not limited to synchronising between clients and servers. \
                    It can also be used to synchronise calendars and/or addressbooks between two \
                    servers directly. It aims to be for calendars and contacts what OfflineIMAP is for emails.
license             M.Unterwaditzer contributors

github.setup        pimutils vdirsyncer 4730857fa5dc619763498a1d45e0ee9c2da87b39
## pip requires a "fully intact git repository"
fetch.type          git
version             0.20.0.46
homepage            https://vdirsyncer.pimutils.org

checksums           rmd160  8e30b3ae2bc48a22ad984ef35df8373440ca89e7 \
                    sha256  a789c2ce8726ae8cdb149c36c21cccc759c1da1fcb286fbdeb6c85ce7adb26f0
#                     size    125666

## == python version variant generation borrowed from port:mpv ==
python.default_version 311
python.versions     39 310 311 312 313 314

python.version      ""

# Create python variants.
foreach ver ${python.versions} {
    set variant_line {variant python${ver} description }
    set python.branch [string index $ver 0].[string range $ver 1 end]
    append variant_line " {Use Python ${python.branch} to run ${name}}"

    foreach over ${python.versions} {
        if {${ver} == ${over}} {
            continue
        }

        append variant_line " conflicts python${over}"
    }

    append variant_line " {
    }"
    eval $variant_line
}

# Set default python variant.
set variant_none true
foreach ver ${python.versions} {
    if {[variant_isset python${ver}]} {
        set variant_none [expr $variant_none && ![variant_isset python${ver}]]
    }
}

if {${variant_none}} {
    default_variants-append "+python${python.default_version}"
}

# Set ${python.version} to the currently active variant.
foreach ver ${python.versions} {
    if {[variant_isset python${ver}]} {
        set python.version ${ver}
        set python.branch [string index ${python.version} 0].[string range ${python.version} 1 end]
    }
}

if {[string length ${python.version}] == 0} {
    ui_error "No python variant selected. You must select at least one. The highest value will be used."
    error "Select a python variant."
}

set python_ver_dot [string index ${python.version} 0].[string range ${python.version} 1 end]
## ==============================================================

depends_build-append \
                    port:py${python.version}-pip

## These are the dependencies that are currently in MacPorts.
## Let pip pull in the few remaining ones, and update the
## port when those are added to the ports tree.
## tenacity, click_log, aiostream
depends_run-append  port:py${python.version}-urllib3 \
                    port:py${python.version}-typing_extensions \
                    port:py${python.version}-propcache \
                    port:py${python.version}-multidict \
                    port:py${python.version}-idna \
                    port:py${python.version}-frozenlist \
                    port:py${python.version}-click \
                    port:py${python.version}-certifi \
                    port:py${python.version}-attrs \
                    port:py${python.version}-aiohappyeyeballs \
                    port:py${python.version}-yarl \
                    port:py${python.version}-requests \
                    port:py${python.version}-aiosignal \
                    port:py${python.version}-aiohttp

use_configure       no

## destroot using pip implementation taken from port:py-mkl
build {}

python.move_binaries no

destroot.cmd        pip-${python.branch}
destroot.args       install \
                    --compile \
                    --no-cache-dir     \
                    --root ${destroot} \
                    ${worksrcpath}
destroot.post_args
