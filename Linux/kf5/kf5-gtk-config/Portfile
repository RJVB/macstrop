# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
set kf5.project     kde-gtk-config
set kf5.virtualPath plasma
PortGroup           kf5 1.1
set kf5.latest_plasma 5.20.5
kf5.use_latest  plasma

description         KDE GTK Configurator
long_description    This project aims to provide a smooth experience for the users of \
                    GNOME/GTK applications on Plasma Desktop. It syncs a large number \
                    of KDE appearance settings with GTk applications, like the layout \
                    of titlebar buttons.

categories          x11 gtk kde
license             LGPL-2+

maintainers         gmail.com:rjvbertin openmaintainer

fetch.type          git
kf5.git.shallowbefore no
kf5.git.setup       kde kde-gtk-config 5.20.5 v
name                kf5-gtk-config
distname            ${name}-git

# use_xz              yes
installs_libs       no

qt5.depends_component \
                    qtsvg

kf5.depends_frameworks \
                    kdbusaddons \
                    kconfig \
                    kconfigwidgets \
                    kcoreaddons \
                    kguiaddons


depends_lib-append  port:gtk2 \
                    port:gtk3 \
                    port:glib2 \
                    port:kf5-kdecoration

depends_build-append \
                    port:sassc

patch.pre_args      -Np1
patchfiles-append   patch-support-older-qt5kf.diff

build.post_args-append \
                    -wk

livecheck.type      regex
livecheck.url       http://download.kde.org/stable/plasma/
livecheck.regex     (5+(\\.\\d+)+)
