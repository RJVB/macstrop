+int RulesWidget::desktopToCombo(int d) const
+{
+    if (d >= 1 && d < desktop->count())
+        return d - 1;
+    return desktop->count() - 1; // on all desktops
+}
+
+int RulesWidget::comboToDesktop(int val) const
+{
+    if (val == desktop->count() - 1)
+        return NET::OnAllDesktops;
+    return val + 1;
+}
