-void RuleItem::reset()
-{
-    m_enabled = hasFlag(AlwaysEnabled) | hasFlag(StartEnabled);
-    m_value = typedValue(QVariant(), m_type);
-    m_suggestedValue = QVariant();
-    m_policy->resetValue();
-    if (m_options) {
-        m_options->resetValue();
-    }
-}
-
-QString RuleItem::key() const
-{
-    return m_key;
-}
-
-QString RuleItem::name() const
