+static const char* tbl_num_lookup(const char* const arr[], int pos)
+{
+    for (int i = 0;
+            arr[ i ][ 0 ] != '\0' && pos >= 0;
+            ++i) {
+        if (pos == 0)
+            return arr[ i ];
+        --pos;
+    }
+    abort(); // should never happen this way
+}
+
+static int tbl_txt_lookup(const char* const arr[], const char* txt)
+{
+    int pos = 0;
+    for (int i = 0;
+            arr[ i ][ 0 ] != '\0';
+            ++i) {
+        if (qstricmp(txt, arr[ i ]) == 0)
+            return pos;
+        ++pos;
+    }
+    return 0;
+}
