if {${subport} eq "kf5-kwin"} {
    conflicts       kf5-kwin-devel
    revision        5
    kf5.use_latest  plasma
    checksums       rmd160  c51c1e759bb41704f1ad18ca3d6223c21b9e2b69 \
                    sha256  e341c8165354643fd201292e53418050970bf8819b2cd0dd932423a342d2f805
#                     size    6237440
    patchfiles-append \
                    kwin/patch-add-sys_types.diff \
                    kwin/patch-nosetcap.diff \
                    kwin/patch-colour-management2.diff \
                    kwin/patch-older-deps.diff \
                    kwin/patch-comptoggle-action.diff \
                    kwin/patch-scroll-raise.diff \
                    kwin/patch-detect-more-gpus.diff
}

subport kf5-kwin-devel {
    conflicts       kf5-kwin
    revision        4
    long_description-append \
                    A somewhat more recent version, which provides better titlebar decorations \
                    for GTk3+ applications using client-side-decoration.\n\
                    NB: a hack and still work in progress.
    # last commit before the port to kwayland-server:
    git.branch      137a6a170520ad5471106665dbb93a1298cc35f1
    version         5.18.4.1.226
    distname        kwin-git
    patchfiles-append \
                    kwin-devel/patch-add-sys_types.diff \
                    kwin-devel/patch-nosetcap.diff \
                    kwin-devel/patch-colour-management2.diff \
                    kwin-devel/patch-comptoggle-action.diff \
                    kwin-devel/patch-scroll-raise.diff \
                    kwin-devel/patch-older-deps-fixed.diff \
                    kwin-devel/patch-detect-more-gpus.diff
## KCMs notes
#                   kwinoptions replaced with the one from kwin 5.15.5
#                   kwinrules replaced with the one from before D D28152, dropping QML
#                     NB: KCMs in the kcms subdir are expected to link QtQuick and crash if not!!!
#                   kcm_kwin_effects was merged back with kwincompositing which was reverted to
#                   the version in 5.15.5; idem a number of the builtin effects
    patchfiles-append \
                    kwin-devel/patch-kwinoptions-from-5.15.5.diff \
                    kwin-devel/patch-kwinrules-revert-D28152.diff \
                    kwin-devel/patch-kwincompositing-and-select-effects-from-5.15.5-fixed.diff
## KCMs currently not working:
#                     kcm_kwin_virtualdesktops (idem in port:kf5-kwin BTW)
#                     (kwindecoration taken from KWin 5.15.5 complains about reading closeOnDoubleClickOnMenu "of null" \
#                      in aurorae/MenuButton.qml, which is weird because that the property should be defined.)
    post-destroot {
        # aurorae-based window decorations are crippled in this hacked version, so disable them:
        file delete -force ${destroot}${prefix}/share/knsrcfiles/aurorae.knsrc
        file delete -force ${destroot}${prefix}/share/kwin/aurorae
        file delete -force ${destroot}${prefix}/share/qt5/plugins/kpackage/packagestructure/kwin_packagestructure_aurorae.so
        file delete -force ${destroot}${prefix}/share/qt5/plugins/org.kde.kdecoration2/kwin5_aurorae.so
    }
}

# the shared code for the kf5-kwin ports:
if {${subport} eq "kf5-kwin" || ${subport} eq "kf5-kwin-devel"} {
    kf5.depends_qt5_components \
                    qtdeclarative qtscript qttools qtwayland
    kf5.depends_frameworks \
                    kactivities kcmutils kcompletion kconfig kconfigwidgets \
                    kcoreaddons kcrash kdeclarative kdoctools kglobalaccel \
                    ki18n kiconthemes kidletime kinit kio knewstuff \
                    knotifications kpackage kservice ktextwidgets kwayland \
                    kwidgetsaddons kwindowsystem kxmlgui plasma-framework 
    depends_lib-append \
                    port:kf5-kdecoration \
                    port:kf5-kscreenlocker \
                    port:libxkbcommon \
                    port:libepoxy \
                    port:wayland \
                    port:xorg-libxcb \
                    port:lcms2 \
                    port:systemd \
                    port:libdrm \
                    port:mesa \
                    port:libinput
    post-destroot {
        # these won't work because of missing QML dependencies:
        file delete -force ${destroot}${prefix}/share/kwin/scripts/desktopchangeosd
        file delete -force ${destroot}${prefix}/share/kwin/virtualkeyboard
    }
}

kf5.allow_apidocs_generation no

