# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           gitlab 1.1
PortGroup           cmake 1.1
PortGroup           openssl 1.0
if {[variant_isset kwallet]} {
    PortGroup       kf5 1.1
}
PortGroup           LTO 1.0

git.fetch_submodules no
git.shallow_since   2025-01-01
gitlab.setup        Remmina Remmina dde6e72974fa75f40064de5e3734373ecb4c1c7c
fetch.type          git
distname            ${name}-git
version             1.4.43.17

categories          gnome,net
license             LGPL-2.1+
maintainers         openmaintainer
description         The GTK Remmina Remote Desktop Client
long_description    Remmina remote desktop client \
                    Use other desktops remotely, from a tiny screen or large monitors. \
                    RDP, VNC, SPICE, X2Go, SSH, WWW (HTTP protocol) and EXEC network protocols are supported. \
platforms           darwin linux

depends_build-append \
                    port:libxml2 \
                    port:pkgconfig

depends_lib-append \
                    path:lib/pkgconfig/gtk+-3.0.pc:gtk3 \
                    port:freerdp \
                    port:LibVNCServer \
                    port:libsodium \
                    port:libgcrypt \
                    port:libssh \
                    port:vte \
                    port:json-glib \
                    port:libsecret \
                    port:pcre2
platform linux {
    depends_build-append \
                    port:wayland-protocols
    depends_lib-append \
                    port:wayland \
                    port:avahi
}

# tweak the cleverness around CMAKE_BUILD_TYPE
# and make certain to link in our libwayland-client on Linux
patchfiles-append   patch-cmake-mp.diff

configure.args-append \
                    -DWITH_NEWS=OFF \
                    -DWITH_TIP=OFF \
                    -DWITH_ICON_CACHE=OFF \
                    -DWITH_UPDATE_DESKTOP_DB=OFF \
                    -DHAVE_LIBAPPINDICATOR=OFF \
                    -DWITH_SPICE=OFF \
                    -DWITH_WWW=OFF \
                    -DWITH_WEBKIT2GTK=OFF \
                    -DWITH_EXAMPLES=OFF \
                    -DWITH_KF5WALLET=OFF \
                    -DWITH_PYTHONLIBS=OFF

variant kwallet description {build support for the KF5 wallet} {
    kf5.depends_frameworks kwallet
    configure.args-replace \
                    -DWITH_KF5WALLET=OFF \
                    -DWITH_KF5WALLET=ON
}

variant spice description {build support for the Spice protocol} {
    depends_lib-append \
                    port:spice-gtk
    configure.args-replace \
                    -DWITH_SPICE=OFF \
                    -DWITH_SPICE=ON
}

variant webkit_4.0 conflicts webkit_4.1 description {build the WWW plugin} {
    depends_lib-append \
                    path:lib/pkgconfig/webkit2gtk-4.0.pc:webkit2-gtk-4.0
    configure.args-replace \
                    -DWITH_WWW=OFF \
                    -DWITH_WWW=ON \
                    -DWITH_WEBKIT2GTK=OFF \
                    -DWITH_WEBKIT2GTK=ON
}

variant webkit_4.1 conflicts webkit_4.0 description {build the WWW plugin} {
    depends_lib-append \
                    path:lib/pkgconfig/webkit2gtk-4.1.pc:webkit2-gtk-4.1
    configure.args-replace \
                    -DWITH_WWW=OFF \
                    -DWITH_WWW=ON \
                    -DWITH_WEBKIT2GTK=OFF \
                    -DWITH_WEBKIT2GTK=ON
}

# gobject-introspection uses g-ir-scanner, which uses $CC from env
if {${universal_possible} && [variant_isset universal]} {
    foreach arch ${configure.universal_archs} {
        lappend merger_build_env(${arch}) \
                    "CC=${configure.cc} -arch ${arch}"
        lappend merger_destroot_env(${arch}) \
                    "CC=${configure.cc} -arch ${arch}"
    }
} else {
    build.env-append \
                    "CC=${configure.cc} ${configure.cc_archflags}"
    destroot.env-append \
                    "CC=${configure.cc} ${configure.cc_archflags}"
}

build.post_args     -wk

post-activate {
    catch {system "xdg-icon-resource forceupdate --theme hicolor"}
    system "env XDG_DATA_DIRS=${prefix}/share ${prefix}/bin/update-mime-database -V ${prefix}/share/mime"
}
